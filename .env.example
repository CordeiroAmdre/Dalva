# OpenAI (required)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Application
APP_HOST=127.0.0.1
APP_PORT=8000

# Optional: enable read-only PDV database queries via DuckDB
DATABASE_QUERIES_ENABLED=false
DATABASE_URL=duckdb:///./data/pdv_ai.duckdb
DATABASE_SCHEMA=pdv
DATABASE_QUERY_TIMEOUT_SEC=10
DATABASE_MAX_ROWS=100
SQL_AGENT_MAX_ITERATIONS=8
